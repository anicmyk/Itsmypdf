---
import { PdfUploadHero } from '@/components/pdf/shared/PdfUploadHero';
import ToolLongform from '@/components/ToolLongform.astro';
import { TOOL_HERO_UI } from '@/lib/toolHeroConfig';
import { TOOL_LONGFORM } from '@/lib/toolLongform';

interface Props {
  title?: string;
  description?: string;
  toolId?: string;
  accept?: string;
  multiple?: boolean;
}

const { title, description, toolId, accept, multiple } = Astro.props;
const hero = toolId ? TOOL_HERO_UI[toolId] : undefined;
const resolvedTitle = hero?.title ?? title ?? 'PDF Tool';
const resolvedDescription = hero?.description ?? description;
const resolvedAccept = hero?.accept ?? accept;
const resolvedMultiple = hero?.multiple ?? multiple;
const resolvedButtonLabel = hero?.buttonLabel;
const resolvedDropLabel = hero?.dropLabel;
const noop = () => {};
const hasLongform = Boolean(toolId && TOOL_LONGFORM[toolId]);
---
<div
  class={`flex flex-col h-full w-full bg-gray-50 font-sans ${hasLongform ? 'overflow-y-scroll' : 'overflow-hidden'}`}
  style={hasLongform ? 'scrollbar-gutter: stable;' : undefined}
>
  <div class="flex-grow flex items-center justify-center p-4 md:p-8">
    <PdfUploadHero
      onFilesSelect={noop}
      title={resolvedTitle}
      description={resolvedDescription}
      accept={resolvedAccept}
      multiple={resolvedMultiple}
      buttonLabel={resolvedButtonLabel}
      dropLabel={resolvedDropLabel}
    />
  </div>
  <ToolLongform toolId={toolId} />
</div>
