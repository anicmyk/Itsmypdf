---
import Header from '@/components/Header.astro';
import SeoHead from '@/components/SeoHead.astro';
import ToasterMount from '@/components/ToasterMount';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const { title, description = 'Free privacy-first PDF tools.', canonical, noindex = false, ogImage = '/og-image.jpg', ogType = 'website' } = Astro.props;
---
<html lang="en">
  <head>
    <SeoHead title={title} description={description} canonical={canonical} noindex={noindex} ogImage={ogImage} ogType={ogType} />
  </head>
  <body class="text-gray-900 tool-layout">
    <div class="flex flex-col bg-gray-50 h-screen overflow-hidden">
      <Header />
      <main class="tool-main flex-1 pt-16 overflow-hidden min-h-0 flex flex-col">
        <div class="tool-slot flex-1 min-h-0">
          <slot />
        </div>
      </main>
    </div>
    <ToasterMount client:load />
    <script is:inline>
      const resetToolScroll = () => {
        window.scrollTo({ top: 0, left: 0, behavior: 'auto' });

        const scope = document.querySelector('.tool-layout .tool-slot');
        if (!scope) return;

        const nodes = scope.querySelectorAll('*');
        nodes.forEach((node) => {
          if (!(node instanceof HTMLElement)) return;

          const style = window.getComputedStyle(node);
          const canScrollY = /(auto|scroll)/.test(style.overflowY) && node.scrollHeight > node.clientHeight;

          if (canScrollY) {
            node.scrollTop = 0;
          }
        });
      };

      const scheduleReset = () => {
        requestAnimationFrame(() => {
          requestAnimationFrame(resetToolScroll);
        });
      };

      window.history.scrollRestoration = 'manual';
      document.addEventListener('astro:page-load', scheduleReset);
      window.addEventListener('load', scheduleReset);
      window.addEventListener('pageshow', scheduleReset);
    </script>
  </body>
</html>
