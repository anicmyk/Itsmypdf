---
import Header from '@/components/Header.astro';
import SeoHead from '@/components/SeoHead.astro';
import ToasterMount from '@/components/ToasterMount';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
}

const { title, description = 'Free privacy-first PDF tools.', canonical, noindex = false, ogImage = '/og-image.jpg' } = Astro.props;
---
<html lang="en">
  <head>
    <SeoHead title={title} description={description} canonical={canonical} noindex={noindex} ogImage={ogImage} />
  </head>
  <body class="text-gray-900">
    <div class="flex flex-col bg-gray-50 h-screen overflow-hidden">
      <Header />
      <main class="flex-1 pt-16 overflow-hidden min-h-0">
        <slot />
      </main>
    </div>
    <ToasterMount client:load />
  </body>
</html>
