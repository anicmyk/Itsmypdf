---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeToolsGrid from '@/components/home/HomeToolsGrid';
import { HOMEPAGE_SEO } from '@/lib/seoData';
import { CheckCircle, Zap, Lock } from 'lucide-react';
---
<BaseLayout title={HOMEPAGE_SEO.title} description={HOMEPAGE_SEO.description} canonical="/">
  <div class="min-h-screen bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-12">
      <div class="text-center mb-6">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 mb-3">
          Your Files Never Leave Your Device
        </h1>
        <p class="text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto mb-6 px-4">
          Your files stay on your computer while you merge, split, compress, and convert. Completely free to use.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6 px-4">
          <div class="flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-blue-600 font-medium text-sm shadow-sm">
            <CheckCircle className="w-5 h-5 mr-2 text-blue-600" />
            No Account Required
          </div>
          <div class="flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-blue-600 font-medium text-sm shadow-sm">
            <Zap className="w-5 h-5 mr-2 text-blue-600" />
            Instant Processing
          </div>
          <div class="flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-blue-600 font-medium text-sm shadow-sm">
            <Lock className="w-5 h-5 mr-2 text-blue-600" />
            100% Private
          </div>
        </div>

        <HomeToolsGrid client:load />
      </div>
    </div>

    <div class="bg-gray-50 py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">
            Frequently Asked Questions
          </h2>
          <p class="text-lg text-gray-600">
            Everything you need to know about our PDF tools
          </p>
        </div>

        <div class="space-y-6">
          <div class="bg-white rounded-lg p-8 shadow-sm min-h-[140px]">
            <h3 class="font-semibold text-gray-900 mb-2">Is this really free?</h3>
            <p class="text-gray-600">Yes! All our PDF tools are completely free to use with no hidden fees, subscriptions, or limits.</p>
          </div>

          <div class="bg-white rounded-lg p-8 shadow-sm min-h-[140px]">
            <h3 class="font-semibold text-gray-900 mb-2">How does local processing work?</h3>
            <p class="text-gray-600">All file processing happens directly in your browser using advanced JavaScript. Your files never leave your device, ensuring complete privacy and security.</p>
          </div>

          <div class="bg-white rounded-lg p-8 shadow-sm min-h-[140px]">
            <h3 class="font-semibold text-gray-900 mb-2">What about my privacy?</h3>
            <p class="text-gray-600">Your privacy is our top priority. We don't store, track, or access any of your files. Everything is processed locally and securely.</p>
          </div>

          <div class="bg-white rounded-lg p-8 shadow-sm min-h-[140px]">
            <h3 class="font-semibold text-gray-900 mb-2">Are there file size limits?</h3>
            <p class="text-gray-600">Most tools can handle files up to 50MB. For larger files, we recommend splitting them into smaller chunks for optimal performance.</p>
          </div>

          <div class="bg-white rounded-lg p-8 shadow-sm min-h-[140px]">
            <h3 class="font-semibold text-gray-900 mb-2">What browsers are supported?</h3>
            <p class="text-gray-600">Our tools work on all modern browsers including Chrome, Firefox, Safari, and Edge. No downloads or installations required.</p>
          </div>

          <div class="bg-white rounded-lg p-8 shadow-sm min-h-[140px]">
            <h3 class="font-semibold text-gray-900 mb-2">How can I report a bug or suggest a feature?</h3>
            <p class="text-gray-600">We'd love to hear from you! Contact us through the support section below with any feedback, bug reports, or feature requests.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
