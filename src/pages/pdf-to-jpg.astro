---
import ToolLayout from '@/layouts/ToolLayout.astro';
import PdfToJpgTool from '@/components/pdf/PdfToJpgTool/PdfToJpgTool';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'pdf-to-jpg';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/pdf-to-jpg'} ogImage={getOgImagePath(toolId)}>
  <PdfToJpgTool client:only="react" />
</ToolLayout>
