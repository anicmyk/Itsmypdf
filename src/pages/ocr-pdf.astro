---
import ToolLayout from '@/layouts/ToolLayout.astro';
import OcrPDFTool from '@/components/pdf/ocr/OcrPDFTool';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'ocr-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/ocr-pdf'} ogImage={getOgImagePath(toolId)}>
  <OcrPDFTool client:only="react" />
</ToolLayout>
