---
import ToolLayout from '@/layouts/ToolLayout.astro';
import RotatePDFTool from '@/components/pdf/rotate/RotatePDFTool';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'rotate-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/rotate-pdf'} ogImage={getOgImagePath(toolId)}>
  <RotatePDFTool client:only="react" />
</ToolLayout>
