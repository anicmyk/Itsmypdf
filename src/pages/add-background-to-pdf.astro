---
import ToolLayout from '@/layouts/ToolLayout.astro';
import AddBackgroundTool from '@/components/pdf/add-background/AddBackgroundTool';
import ToolShell from '@/components/ToolShell.astro';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'add-background-to-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/add-background-to-pdf'} ogImage={getOgImagePath(toolId)}>
  <AddBackgroundTool client:only="react">
    <ToolShell slot="fallback" toolId={toolId} />
  </AddBackgroundTool>
</ToolLayout>


