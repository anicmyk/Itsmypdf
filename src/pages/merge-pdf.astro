---
import ToolLayout from '@/layouts/ToolLayout.astro';
import MergePDFTool from '@/components/pdf/merge/MergePDFTool';
import ToolShell from '@/components/ToolShell.astro';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'merge-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/merge-pdf'} ogImage={getOgImagePath(toolId)}>
  <MergePDFTool client:only="react">
    <ToolShell slot="fallback" toolId={toolId} />
  </MergePDFTool>
</ToolLayout>


