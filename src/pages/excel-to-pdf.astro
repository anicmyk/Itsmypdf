---
import ToolLayout from '@/layouts/ToolLayout.astro';
import ExcelToPdfTool from '@/components/pdf/excel-to-pdf/ExcelToPdfTool';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'excel-to-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/excel-to-pdf'} ogImage={getOgImagePath(toolId)}>
  <ExcelToPdfTool client:only="react" />
</ToolLayout>
