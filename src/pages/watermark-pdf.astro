---
import ToolLayout from '@/layouts/ToolLayout.astro';
import WatermarkPDFTool from '@/components/pdf/watermark/WatermarkPDFTool';
import ToolShell from '@/components/ToolShell.astro';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'watermark-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/watermark-pdf'} ogImage={getOgImagePath(toolId)}>
  <WatermarkPDFTool client:only="react">
    <ToolShell slot="fallback" toolId={toolId} />
  </WatermarkPDFTool>
</ToolLayout>


