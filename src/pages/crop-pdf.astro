---
import ToolLayout from '@/layouts/ToolLayout.astro';
import CropPDFTool from '@/components/pdf/crop/CropPDFTool';
import ToolShell from '@/components/ToolShell.astro';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'crop-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/crop-pdf'} ogImage={getOgImagePath(toolId)}>
  <CropPDFTool client:only="react">
    <ToolShell slot="fallback" title={seo?.h1 ?? seo?.title ?? 'PDF Tool'} description={seo?.description ?? 'PDF tool'} />
  </CropPDFTool>
</ToolLayout>
