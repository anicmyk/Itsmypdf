---
import ToolLayout from '@/layouts/ToolLayout.astro';
import EditPdfTool from '@/components/pdf/edit/EditPdfTool';
import ToolShell from '@/components/ToolShell.astro';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'edit-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/edit-pdf'} ogImage={getOgImagePath(toolId)}>
  <EditPdfTool client:only="react">
    <ToolShell slot="fallback" toolId={toolId} />
  </EditPdfTool>
</ToolLayout>
