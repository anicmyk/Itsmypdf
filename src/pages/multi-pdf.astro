---
import ToolLayout from '@/layouts/ToolLayout.astro';
import MultiPDFTool from '@/components/pdf/multi/MultiPDFTool';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'multi-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/multi-pdf'} ogImage={getOgImagePath(toolId)}>
  <MultiPDFTool client:only="react" />
</ToolLayout>
