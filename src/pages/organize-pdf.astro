---
import ToolLayout from '@/layouts/ToolLayout.astro';
import OrganizePDFTool from '@/components/pdf/OrganizePDF/OrganizePDFTool';
import ToolShell from '@/components/ToolShell.astro';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'organize-pdf';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/organize-pdf'} ogImage={getOgImagePath(toolId)}>
  <OrganizePDFTool client:only="react">
    <ToolShell slot="fallback" toolId={toolId} />
  </OrganizePDFTool>
</ToolLayout>


