---
import ToolLayout from '@/layouts/ToolLayout.astro';
import RemovePagesTool from '@/components/pdf/remove-pages/RemovePagesTool';
import { ALL_TOOLS_SEO } from '@/lib/seoData';
import { getOgImagePath } from '@/lib/ogImages';

const toolId = 'remove-pages';
const seo = ALL_TOOLS_SEO[toolId as keyof typeof ALL_TOOLS_SEO];
---
<ToolLayout title={seo?.title ?? 'itsmypdf Tool'} description={seo?.description ?? 'PDF tool'} canonical={'/remove-pages'} ogImage={getOgImagePath(toolId)}>
  <RemovePagesTool client:only="react" />
</ToolLayout>
